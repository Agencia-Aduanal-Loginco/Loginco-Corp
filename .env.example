# Django
DJANGO_SECRET_KEY=cambia-esto-por-una-clave-secreta-larga
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Base de datos (solo requerido en producción — desarrollo usa SQLite automáticamente)
# DB_NAME=loginco_db
# DB_USER=postgres
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432

# DigitalOcean AI Platform (Gradient)
DO_MODEL_ACCESS_KEY=

# Email — SendGrid SMTP relay
# Obtén tu API key en: https://app.sendgrid.com/settings/api_keys (permiso: Mail Send)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEFAULT_FROM_EMAIL=noreply@loginco.com.mx
CONTACT_EMAIL=contacto@loginco.com.mx

# Media Storage S3-compatible (solo producción)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=

# Cloudflare Stream (opcional, para video streaming)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_TOKEN=
